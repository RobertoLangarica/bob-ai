{
  "instance_id": "bob-ai",
  "name": "bob-ai PR Reviewer",
  "description": "Overthink instance for bob-ai automated code review",
  "repo_root": ".",
  "callsign": "◆ Sentinel",

  "queue": {
    "type": "local",
    "poll_interval_seconds": 30
  },

  "task_specs": [
    {
      "ref": "bob-ai.pr_reviewer",
      "path": "scripts/task-specs/pr-reviewer.v1.json"
    }
  ],

  "scenarios": [
    {
      "ref": "pr-review",
      "path": "scripts/overthink/scenarios/pr-review.json"
    }
  ],

  "artifacts": {
    "reviews_dir": "reviews/",
    "logs_dir": ".overthink/logs/"
  },

  "env_defaults": {
    "REPO": "RobertoLangarica/bob-ai",
    "BASE_REF": "main",
    "GIT_PAGER": "cat"
  }
}
